<div class="min-h-screen flex items-center justify-center bg-slate-950">
  <div class="w-full max-w-md px-8">

    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold text-white tracking-tight">Personal Finance</h1>
      <p class="text-slate-400 mt-2 text-sm">Sign in to your account</p>
    </div>

    <div class="bg-slate-900 rounded-2xl p-8 shadow-2xl border border-slate-800">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <div class="mb-5">
          <%= f.label :email, class: "block text-sm font-medium text-slate-300 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                            class: "w-full bg-slate-800 border border-slate-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition" %>
        </div>

        <div class="mb-5">
          <%= f.label :password, class: "block text-sm font-medium text-slate-300 mb-2" %>
          <%= f.password_field :password, autocomplete: "current-password",
                               class: "w-full bg-slate-800 border border-slate-700 text-white rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center mb-6">
            <%= f.check_box :remember_me, class: "checkbox checkbox-sm border-slate-600" %>
            <%= f.label :remember_me, class: "ml-2 text-sm text-slate-400 cursor-pointer" %>
          </div>
        <% end %>

        <div class="mt-6">
          <%= f.submit "Sign in", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 rounded-lg text-sm transition cursor-pointer" %>
        </div>

      <% end %>

      <div class="mt-6 text-center text-slate-500 text-sm">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>